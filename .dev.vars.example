# Server-side generation token. Never use NEXT_PUBLIC_ and never commit the real value.
KIE_API_KEY=replace-with-your-private-api-key

# Protects paid generation on the public site. Enter the same code in the owner field.
STUDIO_ACCESS_CODE=choose-a-long-private-code

# Optional service overrides. The defaults already point at the production APIs.
# KIE_API_BASE_URL=https://api.kie.ai
# KIE_UPLOAD_BASE_URL=https://kieai.redpandaai.co

# Keep paid generation owner-only until SHAZAN login, wallet, quotas and abuse limits exist.
# STUDIO_ALLOW_PUBLIC=false
