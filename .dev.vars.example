# Primary server-side generation token. Never use NEXT_PUBLIC_ and never commit the real value.
FAL_KEY=replace-with-your-private-fal-key

# OpenAI Speech API for the GPT Voice generator.
OPENAI_API_KEY=replace-with-your-private-openai-key

# Owner gate stays enabled until SHAZAN user accounts and credit wallets launch.
STUDIO_ACCESS_CODE=replace-with-a-long-private-owner-code

# Optional fallback for Seedance Mini and Kling Elements.
KIE_API_KEY=replace-with-your-private-kie-key

# Optional service overrides. The defaults already point at the production APIs.
# KIE_API_BASE_URL=https://api.kie.ai
# KIE_UPLOAD_BASE_URL=https://kieai.redpandaai.co
# FAL_QUEUE_BASE_URL=https://queue.fal.run
# FAL_STORAGE_BASE_URL=https://rest.fal.ai
